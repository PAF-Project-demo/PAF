MONGODB_PASSWORD=replace-with-your-atlas-password
MONGODB_DATABASE=paf_auth
GOOGLE_CLIENT_ID=replace-with-your-google-web-client-id.apps.googleusercontent.com
LINKEDIN_CLIENT_ID=replace-with-your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=replace-with-your-linkedin-client-secret
# Register this backend callback in the LinkedIn Developer Portal.
LINKEDIN_REDIRECT_URI=http://localhost:8081/api/auth/linkedin/callback
# App location to open after the backend finishes OAuth successfully.
LINKEDIN_CLIENT_REDIRECT_URI=http://localhost:5173/
GITHUB_CLIENT_ID=replace-with-your-github-oauth-client-id
GITHUB_CLIENT_SECRET=replace-with-your-github-oauth-client-secret
# Register this backend callback in your GitHub OAuth app settings.
GITHUB_REDIRECT_URI=http://localhost:8081/api/auth/github/callback
# App location to open after the backend finishes OAuth successfully.
GITHUB_CLIENT_REDIRECT_URI=http://localhost:5173/
