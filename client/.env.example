# Client-side environment variables. Copy this file to `.env` and fill in real values.
# Never commit the real `.env` — it is gitignored.

# Base URL of the Spring Boot backend (see server/.env.example for backend config).
VITE_API_BASE_URL=http://localhost:8081

# Google OAuth web client ID from https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=replace-with-your-google-web-client-id.apps.googleusercontent.com
